      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{BDE53827-EEB3-4BBB-8F4F-C598A8529D1D}"
          SQLTask:SqlStatementSource="IF OBJECT_ID('[stg_computer_sales].[dbo].[dim_customer_details]', 'U') IS NULL&#xA;BEGIN&#xA;    CREATE TABLE [stg_computer_sales].[dbo].[dim_customer_details] (&#xA;        customer_id INT IDENTITY(1,1) PRIMARY KEY,&#xA;        customer_name NVARCHAR(100) NOT NULL,&#xA;        customer_surname NVARCHAR(100) NOT NULL,&#xA;        customer_contact_number NVARCHAR(100) NOT NULL,&#xA;        customer_email_address NVARCHAR(150) NOT NULL&#xA;    );&#xA;END;&#xA;GO" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
