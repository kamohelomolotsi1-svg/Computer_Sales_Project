      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{BDE53827-EEB3-4BBB-8F4F-C598A8529D1D}"
          SQLTask:SqlStatementSource="IF DB_ID('clean_computer_sales') IS NULL&#xA;BEGIN&#xA;    CREATE DATABASE clean_computer_sales;&#xA;END;&#xA;GO&#xA;&#xA;IF OBJECT_ID('[clean_computer_sales].[dbo].[pc_sales_fact]', 'U') IS NULL&#xA;BEGIN&#xA;    CREATE TABLE [clean_computer_sales].[dbo].[pc_sales_fact] (&#xA;        pc_sales_fact_id INT IDENTITY(1,1) PRIMARY KEY,&#xA;        customer_id INT NOT NULL,&#xA;        location_id INT NOT NULL,&#xA;        pc_product_id INT NOT NULL,&#xA;        channel_id INT NOT NULL,&#xA;        payment_id INT NOT NULL,&#xA;        sales_person_id INT NOT NULL,&#xA;        date_id INT NOT NULL,&#xA;        shop_id INT NOT NULL,&#xA;        priority_id INT NOT NULL,&#xA;        cost_price DECIMAL(18,2) NULL,&#xA;        sale_price DECIMAL(18,2) NULL,&#xA;        discount_amount DECIMAL(18,2) NULL,&#xA;        finance_amount DECIMAL(18,2) NULL,&#xA;        credit_score INT NULL,&#xA;        total_sales_per_employee DECIMAL(18,2) NULL,&#xA;        pc_market_price DECIMAL(18,2) NULL,&#xA;        CONSTRAINT [FK_clean_pc_sales_fact_customer] FOREIGN KEY (customer_id)&#xA;            REFERENCES [clean_computer_sales].[dbo].[dim_customer_details] (customer_detail_id),&#xA;        CONSTRAINT [FK_clean_pc_sales_fact_location] FOREIGN KEY (location_id)&#xA;            REFERENCES [clean_computer_sales].[dbo].[dim_locations] (location_id),&#xA;        CONSTRAINT [FK_clean_pc_sales_fact_pc_product] FOREIGN KEY (pc_product_id)&#xA;            REFERENCES [clean_computer_sales].[dbo].[dim_pc_product] (pc_product_id),&#xA;        CONSTRAINT [FK_clean_pc_sales_fact_channel] FOREIGN KEY (channel_id)&#xA;            REFERENCES [clean_computer_sales].[dbo].[dim_channel] (channel_id),&#xA;        CONSTRAINT [FK_clean_pc_sales_fact_payment] FOREIGN KEY (payment_id)&#xA;            REFERENCES [clean_computer_sales].[dbo].[dim_payment_id] (payment_id),&#xA;        CONSTRAINT [FK_clean_pc_sales_fact_sales_person] FOREIGN KEY (sales_person_id)&#xA;            REFERENCES [clean_computer_sales].[dbo].[dim_sales_person] (sales_person_id),&#xA;        CONSTRAINT [FK_clean_pc_sales_fact_date] FOREIGN KEY (date_id)&#xA;            REFERENCES [clean_computer_sales].[dbo].[dim_date] (date_id),&#xA;        CONSTRAINT [FK_clean_pc_sales_fact_shop] FOREIGN KEY (shop_id)&#xA;            REFERENCES [clean_computer_sales].[dbo].[dim_shop] (shop_id),&#xA;   CONSTRAINT [FK_clean_pc_sales_fact_priority] FOREIGN KEY (priority_id)&#xA;    REFERENCES [clean_computer_sales].[dbo].[dim_priority_id] (priority_id)&#xA;    );&#xA;END;&#xA;GO"
          SQLTask:TypeConversionMode="None" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
