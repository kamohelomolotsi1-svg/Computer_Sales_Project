      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{BDE53827-EEB3-4BBB-8F4F-C598A8529D1D}"
          SQLTask:SqlStatementSource="IF DB_ID('clean_computer_sales') IS NULL&#xA;BEGIN&#xA;    CREATE DATABASE clean_computer_sales;&#xA;END;&#xA;GO&#xA;&#xA;IF OBJECT_ID('[clean_computer_sales].[dbo].[dim_sales_person]', 'U') IS NULL&#xA;BEGIN&#xA;    CREATE TABLE [clean_computer_sales].[dbo].[dim_sales_person] (&#xA;        sales_person_id INT IDENTITY(1,1) PRIMARY KEY,&#xA;        sales_person_name NVARCHAR(100) NOT NULL,&#xA;        sales_person_department NVARCHAR(100) NOT NULL&#xA;    );&#xA;END;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Create_stg_Sales_Person"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Create_stg_Sales_Person"
      DTS:DTSID="{25DB1041-73A1-4B84-BC51-C84C8295BD44}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Create_stg_Sales_Person"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{BDE53827-EEB3-4BBB-8F4F-C598A8529D1D}"
          SQLTask:SqlStatementSource="    CREATE TABLE [stg_computer_sales].[dbo].[dim_sales_person] (&#xA;        sales_person_id INT IDENTITY(1,1) PRIMARY KEY,&#xA;        sales_person_name NVARCHAR(100) NOT NULL,&#xA;        sales_person_department NVARCHAR(100) NOT NULL&#xA;    );"
          SQLTask:TypeConversionMode="None" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load_Clean_Dim_ Sales_Person"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Load_Clean_Dim_ Sales_Person"
      DTS:DTSID="{2A40393C-0D37-4577-BCB0-C4F1F3B8302E}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load_Clean_Dim_ Sales_Person"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{BDE53827-EEB3-4BBB-8F4F-C598A8529D1D}"
          SQLTask:SqlStatementSource="INSERT INTO [clean_computer_sales].[dbo].[dim_sales_person] (sales_person_name, sales_person_department)&#xA;SELECT DISTINCT&#xA;    r.[Sales_Person_Name],&#xA;    r.[Sales_Person_Department]&#xA;FROM [stg_computer_sales].[dbo].[raw_pc_data] AS r&#xA;WHERE r.[Sales_Person_Name] IS NOT NULL&#xA;  AND r.[Sales_Person_Department] IS NOT NULL&#xA;  AND NOT EXISTS (&#xA;      SELECT 1&#xA;      FROM [clean_computer_sales].[dbo].[dim_sales_person] AS d&#xA;      WHERE d.sales_person_name = r.[Sales_Person_Name]&#xA;        AND d.sales_person_department = r.[Sales_Person_Department]&#xA;  );" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
