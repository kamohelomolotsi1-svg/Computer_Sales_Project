    <DTS:Executable
      DTS:refId="Package\Load_Clean_Dim_PC_Product"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Load_Clean_Dim_PC_Product"
      DTS:DTSID="{342FFECE-DE75-4579-87F7-E205B90CB4FC}"
