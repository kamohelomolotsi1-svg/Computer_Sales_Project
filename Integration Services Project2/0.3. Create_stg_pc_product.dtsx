          SQLTask:Connection="{BDE53827-EEB3-4BBB-8F4F-C598A8529D1D}"
          SQLTask:SqlStatementSource="IF DB_ID('clean_computer_sales') IS NULL&#xA;BEGIN&#xA;    CREATE DATABASE clean_computer_sales;&#xA;END;&#xA;GO&#xA;&#xA;IF OBJECT_ID('[clean_computer_sales].[dbo].[dim_pc_product]', 'U') IS NULL&#xA;BEGIN&#xA;    CREATE TABLE [clean_computer_sales].[dbo].[dim_pc_product] (&#xA;        pc_product_id INT IDENTITY(1,1) PRIMARY KEY,&#xA;        pc_make NVARCHAR(100) NOT NULL,&#xA;        pc_model NVARCHAR(100) NOT NULL,&#xA;        storage_type NVARCHAR(100) NOT NULL,&#xA;        ram NVARCHAR(50) NOT NULL,&#xA;        storage_capacity NVARCHAR(100) NOT NULL&#xA;    );&#xA;END;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
