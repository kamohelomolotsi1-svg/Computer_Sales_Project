      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{BDE53827-EEB3-4BBB-8F4F-C598A8529D1D}"
          SQLTask:SqlStatementSource="IF OBJECT_ID('[stg_computer_sales].[dbo].[dim_priority]', 'U') IS NULL&#xA;&#xA;BEGIN&#xA;&#xA;CREATE TABLE [stg_computer_sales].[dbo].[dim_priority]&#xA;(&#xA;priority_id INT IDENTITY(1,1) PRIMARY KEY,&#xA;&#xA;priority NVARCHAR(100) NOT NULL&#xA;);&#xA;&#xA;END;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load_Clean_Dim_Priority"
