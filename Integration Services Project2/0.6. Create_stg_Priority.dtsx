        <SQLTask:SqlTaskData
          SQLTask:Connection="{BDE53827-EEB3-4BBB-8F4F-C598A8529D1D}"
          SQLTask:SqlStatementSource="INSERT INTO [stg_computer_sales].[dbo].[dim_priority]&#xA;(priority)&#xA;&#xA;&#xA;SELECT DISTINCT&#xA;&#xA;r.Priority&#xA;&#xA;FROM [stg_computer_sales].[dbo].[raw_pc_data]&#xA; r&#xA;WHERE r.Priority IS NOT NULL&#xA;&#xA;AND &#xA;NOT EXISTS&#xA;&#xA;(&#xA;SELECT 1&#xA;FROM [stg_computer_sales].[dbo].[dim_priority] d&#xA;WHERE d.priority = r.Priority&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
