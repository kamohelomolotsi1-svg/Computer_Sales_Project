      DTS:DTSID="{2EAECC13-8707-4277-828A-543C027B84C0}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load_Clean_Dim_Priority"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{BDE53827-EEB3-4BBB-8F4F-C598A8529D1D}"
          SQLTask:SqlStatementSource="INSERT INTO [clean_computer_sales].[dbo].[dim_priority_id]&#xA;&#xA;(priority)&#xA;&#xA;&#xA;SELECT DISTINCT&#xA;&#xA;r.Priority&#xA;&#xA;FROM [stg_computer_sales].[dbo].[raw_pc_data]&#xA; r&#xA;WHERE r.Priority IS NOT NULL&#xA;&#xA;AND NOT EXISTS&#xA;&#xA;(&#xA;SELECT 1&#xA;FROM [clean_computer_sales].[dbo].[dim_priority_id] d&#xA;&#xA;WHERE d.priority = r.Priority&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
