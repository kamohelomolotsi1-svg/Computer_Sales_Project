      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{BDE53827-EEB3-4BBB-8F4F-C598A8529D1D}"
          SQLTask:SqlStatementSource="IF DB_ID('clean_computer_sales') IS NULL&#xA;BEGIN&#xA;    CREATE DATABASE clean_computer_sales;&#xA;END;&#xA;GO&#xA;&#xA;IF OBJECT_ID('[clean_computer_sales].[dbo].[dim_locations]', 'U') IS NULL&#xA;BEGIN&#xA;    CREATE TABLE [clean_computer_sales].[dbo].[dim_locations] (&#xA;        location_id INT IDENTITY(1,1) PRIMARY KEY,&#xA;        continent NVARCHAR(100) NOT NULL,&#xA;        country_or_state NVARCHAR(100) NOT NULL,&#xA;        province_or_city NVARCHAR(100) NOT NULL&#xA;    );&#xA;END;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Create_stg_Locations"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Create_stg_Locations"
      DTS:DTSID="{1450752F-D590-4EA1-A233-02254B36F1B1}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Create_stg_Locations"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{BDE53827-EEB3-4BBB-8F4F-C598A8529D1D}"
          SQLTask:SqlStatementSource="CREATE TABLE [stg_computer_sales].[dbo].[dim_locations] (&#xA;        location_id INT IDENTITY(1,1) PRIMARY KEY,&#xA;        continent NVARCHAR(100) NOT NULL,&#xA;        country_or_state NVARCHAR(100) NOT NULL,&#xA;        province_or_city NVARCHAR(100) NOT NULL&#xA;    );" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load_Clean_Dim_Customer"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Load_Clean_Dim_Customer"
      DTS:DTSID="{9824C18C-49A1-4407-BC5D-DA71B2E8D11C}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load_Clean_Dim_Customer"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{BDE53827-EEB3-4BBB-8F4F-C598A8529D1D}"
          SQLTask:SqlStatementSource="INSERT INTO [clean_computer_sales].[dbo].[dim_locations] (continent, country_or_state, province_or_city)&#xA;SELECT DISTINCT&#xA;    r.[Continent],&#xA;    r.[Country_or_State],&#xA;    r.[Province_or_City]&#xA;FROM [stg_computer_sales].[dbo].[raw_pc_data] AS r&#xA;WHERE r.[Continent] IS NOT NULL&#xA;  AND r.[Country_or_State] IS NOT NULL&#xA;  AND r.[Province_or_City] IS NOT NULL&#xA;  AND NOT EXISTS (&#xA;      SELECT 1&#xA;      FROM [clean_computer_sales].[dbo].[dim_locations] AS d&#xA;      WHERE d.continent = r.[Continent]&#xA;        AND d.country_or_state = r.[Country_or_State]&#xA;        AND d.province_or_city = r.[Province_or_City]&#xA;  );&#xA;GO" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
