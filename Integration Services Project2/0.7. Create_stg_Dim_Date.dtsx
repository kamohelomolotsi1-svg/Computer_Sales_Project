      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Create_Clean_Dim_Date"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{BDE53827-EEB3-4BBB-8F4F-C598A8529D1D}"
          SQLTask:SqlStatementSource="IF DB_ID('clean_computer_sales') IS NULL&#xA;BEGIN&#xA;    CREATE DATABASE clean_computer_sales;&#xA;&#xA;END;&#xA;&#xA;GO&#xA;&#xA;&#xA;&#xA;IF OBJECT_ID('[clean_computer_sales].[dbo].[dim_date]', 'U') IS NULL&#xA;BEGIN&#xA;    &#xA;&#xA;CREATE TABLE [clean_computer_sales].[dbo].[dim_date]&#xA;    (&#xA;        date_id INT IDENTITY(1,1) PRIMARY KEY,&#xA;&#xA;        full_date DATE NOT NULL,&#xA;&#xA;        calendar_year INT NOT NULL,&#xA;&#xA;        calendar_month INT NOT NULL,&#xA;&#xA;        calendar_day INT NOT NULL,&#xA;&#xA;        day_name NVARCHAR(50) NOT NULL&#xA;    );&#xA;&#xA;END;&#xA;&#xA;GO" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Create_stg_Dim_Date"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Create_stg_Dim_Date"
      DTS:DTSID="{FB670F88-26F2-4177-98A9-28602D66596B}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Create_stg_Dim_Date"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{BDE53827-EEB3-4BBB-8F4F-C598A8529D1D}"
          SQLTask:SqlStatementSource="CREATE TABLE [stg_computer_sales].[dbo].[dim_date] (&#xA;        date_id INT IDENTITY(1,1) PRIMARY KEY,&#xA;        full_date DATE NOT NULL,&#xA;        calendar_year INT NOT NULL,&#xA;        calendar_month INT NOT NULL,&#xA;        calendar_day INT NOT NULL,&#xA;        day_name NVARCHAR(20) NOT NULL&#xA;    );" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load_Clean_Dim_Date"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Load_Clean_Dim_Date"
      DTS:DTSID="{688E2868-FCB6-4E47-8311-7CD089A180A6}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load_Clean_Dim_Date"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{BDE53827-EEB3-4BBB-8F4F-C598A8529D1D}"
          SQLTask:SqlStatementSource="INSERT INTO [clean_computer_sales].[dbo].[dim_date]&#xA;(&#xA;full_date,&#xA;calendar_year,&#xA;calendar_month,&#xA;calendar_day,&#xA;day_name&#xA;)&#xA;&#xA;&#xA;&#xA;SELECT DISTINCT&#xA; dates.full_date,&#xA;YEAR(dates.full_date),&#xA;&#xA;MONTH(dates.full_date),&#xA;&#xA;DAY(dates.full_date),&#xA;&#xA;DATENAME(WEEKDAY, dates.full_date)&#xA;&#xA;&#xA;&#xA;FROM&#xA;&#xA;&#xA;(&#xA;SELECT TRY_CAST(Purchase_Date AS DATE) AS full_date&#xA;&#xA;FROM [stg_computer_sales].[dbo].[raw_pc_data]&#xA;&#xA;UNION&#xA;&#xA;SELECT TRY_CAST(Ship_Date AS DATE)&#xA;&#xA;FROM [stg_computer_sales].[dbo].[raw_pc_data]&#xA;&#xA;) dates&#xA;&#xA;WHERE dates.full_date IS NOT NULL&#xA;&#xA;AND NOT EXISTS&#xA;(&#xA;SELECT 1&#xA;FROM [clean_computer_sales].[dbo].[dim_date] d&#xA;WHERE d.full_date = dates.full_date&#xA;);&#xA;&#xA;&#xA;GO" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load_stg_Dim_Date"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Load_stg_Dim_Date"
      DTS:DTSID="{F0886625-C732-4CDA-BD10-1A3BA98F550E}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load_stg_Dim_Date"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{BDE53827-EEB3-4BBB-8F4F-C598A8529D1D}"
          SQLTask:SqlStatementSource="USE [stg_computer_sales];&#xA;GO&#xA;&#xA;INSERT INTO [stg_computer_sales].[dbo].[dim_date] (full_date, calendar_year, calendar_month, calendar_day, day_name)&#xA;SELECT DISTINCT&#xA;    CAST(r.[Purchase_Date] AS DATE) AS full_date,&#xA;    YEAR(CAST(r.[Purchase_Date] AS DATE)) AS calendar_year,&#xA;    MONTH(CAST(r.[Purchase_Date] AS DATE)) AS calendar_month,&#xA;    DAY(CAST(r.[Purchase_Date] AS DATE)) AS calendar_day,&#xA;    DATENAME(WEEKDAY, CAST(r.[Purchase_Date] AS DATE)) AS day_name&#xA;FROM [stg_computer_sales].[dbo].[raw_pc_data] AS r&#xA;WHERE TRY_CAST(r.[Purchase_Date] AS DATE) IS NOT NULL&#xA;  AND NOT EXISTS (&#xA;      SELECT 1&#xA;      FROM [stg_computer_sales].[dbo].[dim_date] AS d&#xA;      WHERE d.full_date = CAST(r.[Purchase_Date] AS DATE)&#xA;  );&#xA;GO" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
