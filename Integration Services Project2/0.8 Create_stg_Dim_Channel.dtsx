          SQLTask:SqlStatementSource="IF OBJECT_ID('[stg_computer_sales].[dbo].[dim_channel]', 'U') IS NULL&#xA;BEGIN&#xA;    CREATE TABLE [stg_computer_sales].[dbo].[dim_channel] (&#xA;        channel_id INT IDENTITY(1,1) PRIMARY KEY,&#xA;        channel NVARCHAR(100) NOT NULL&#xA;    );&#xA;END;&#xA;GO" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
