      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{BDE53827-EEB3-4BBB-8F4F-C598A8529D1D}"
          SQLTask:SqlStatementSource="INSERT INTO [stg_computer_sales].[dbo].[dim_shop] (shop_name, shop_age)&#xA;SELECT DISTINCT&#xA;    r.[Shop_Name],&#xA;    r.[Shop_Age]&#xA;FROM [stg_computer_sales].[dbo].[raw_pc_data] AS r&#xA;WHERE r.[Shop_Name] IS NOT NULL&#xA;  AND r.[Shop_Age] IS NOT NULL&#xA;  AND NOT EXISTS (&#xA;      SELECT 1&#xA;      FROM [stg_computer_sales].[dbo].[dim_shop] AS d&#xA;      WHERE d.shop_name = r.[Shop_Name]&#xA;        AND d.shop_age = r.[Shop_Age]&#xA;  );" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
