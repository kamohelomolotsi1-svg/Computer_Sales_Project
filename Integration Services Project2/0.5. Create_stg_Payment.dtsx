      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{BDE53827-EEB3-4BBB-8F4F-C598A8529D1D}"
          SQLTask:SqlStatementSource="    CREATE TABLE [stg_computer_sales].[dbo].[dim_payment_id] (&#xA;        payment_id INT IDENTITY(1,1) PRIMARY KEY,&#xA;        payment_method NVARCHAR(100) NOT NULL&#xA;    );" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load_Clean_Dim_Payment"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Load_Clean_Dim_Payment"
      DTS:DTSID="{608AA508-CE73-4A27-9A35-50C4FA5E24B5}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load_Clean_Dim_Payment"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{BDE53827-EEB3-4BBB-8F4F-C598A8529D1D}"
          SQLTask:SqlStatementSource="INSERT INTO [clean_computer_sales].[dbo].[dim_payment_id] (payment_method)&#xA;SELECT DISTINCT&#xA;    r.[Payment_Method]&#xA;FROM [stg_computer_sales].[dbo].[raw_pc_data] AS r&#xA;WHERE r.[Payment_Method] IS NOT NULL&#xA;  AND NOT EXISTS (&#xA;      SELECT 1&#xA;      FROM [clean_computer_sales].[dbo].[dim_payment_id] AS d&#xA;      WHERE d.payment_method = r.[Payment_Method]&#xA;  );" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
